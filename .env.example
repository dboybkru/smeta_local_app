# Прод (docker-compose.yml). Скопировать в .env и заполнить.
SECRET_KEY=
POSTGRES_PASSWORD=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
SITE_ADDRESS=smetaapp.ru
# Прод за внешним nginx: привязать web только к localhost, напр. WEB_HTTP_BIND=127.0.0.1:8081
WEB_HTTP_BIND=80
WEB_HTTPS_BIND=443
FRONTEND_URL=https://smetaapp.ru
BACKEND_URL=https://smetaapp.ru
